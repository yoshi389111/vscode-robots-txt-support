{
	"name": "robots.txt",
	"patterns": [
		{
			"include": "#user-agent"
		},
		{
			"include": "#rule"
		},
		{
			"include": "#global"
		},
		{
			"include": "#unknown-directives"
		},
		{
			"include": "#comments"
		}
	],
	"repository": {
		"user-agent": {
			"match": "^\\s*(?i:(user-agent))\\s*(:)\\s*([^#\\s]*)?",
			"captures": {
				"1": {
					"name": "markup.heading.2.robots-txt"
				},
				"2": {
					"name": "punctuation.colon.separator.robots-txt"
				},
				"3": {
					"name": "string.unquoted.robots-txt"
				}
			}
		},
		"rule": {
			"match": "^\\s*(?i:(disallow|allow|crawl-delay|request-rate|visit-time))\\s*(:)\\s*([^#]*?)\\s*(?=#|$)",
			"captures": {
				"1": {
					"name": "keyword.control.rule.robots-txt"
				},
				"2": {
					"name": "punctuation.colon.separator.robots-txt"
				},
				"3": {
					"name": "string.unquoted.robots-txt"
				}
			}
		},
		"global": {
			"match": "^\\s*(?i:(sitemap|clean-param|host|noindex|robot-version|comment))\\s*(:)\\s*([^#\\s]*)?",
			"captures": {
				"1": {
					"name": "keyword.other.global.robots-txt"
				},
				"2": {
					"name": "punctuation.colon.separator.robots-txt"
				},
				"3": {
					"name": "string.unquoted.robots-txt"
				}
			}
		},
		"unknown-directives": {
			"match": "^\\s*([a-zA-Z_][-a-zA-Z0-9_]*)\\s*(:)",
			"captures": {
				"1": {
					"name": "keyword.operator.unknown-directive.robots-txt"
				},
				"2": {
					"name": "punctuation.colon.separator.robots-txt"
				}
			}
		},
		"comments": {
			"match": "#.*$",
			"name": "comment.line.number-sign.robots-txt"
		}
	},
	"scopeName": "text.robots-txt"
}