{
  "name": "robots-txt-support",
  "displayName": "Robots.txt support",
  "description": "VS Code extension for robots.txt language support.",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "yoshi389111",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoshi389111/vscode-robots-txt-support"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "robots-txt",
        "aliases": [
          "robots.txt",
          "robots-txt"
        ],
        "filenames": [
          "robots.txt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "robots-txt",
        "path": "./snippets/snippets.json"
      }
    ],
    "grammars": [
      {
        "language": "robots-txt",
        "scopeName": "text.robots-txt",
        "path": "./syntaxes/robots-txt.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}